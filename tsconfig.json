{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*":          ["./*"],
      "@theme":       ["./theme/index.ts"],
      "@theme/*":     ["./theme/*"],
      "@utils/*":     ["./utils/*"],
      "@constants/*": ["./constants/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
